## ------------------------------------------------------------
## Unraid + Docker environment template
## ------------------------------------------------------------
## For Unraid "Add Container":
## - Add each key below as an Environment Variable.
## - Do NOT paste this file into the image.
## - Keep DISCORD_TOKEN secret.
##
## Image settings for `docker compose build` / `docker compose push`
## (not required on Unraid if image is already set in the container UI)
## Example for GHCR: ghcr.io/mayvqt/modmail
IMAGE_REPOSITORY=ghcr.io/mayvqt/modmail
IMAGE_TAG=latest

## Host path for SQLite data.
## Unraid example: /mnt/user/appdata/modmail
## In Unraid, map host path -> container path `/data`.
MODMAIL_DATA_DIR=./data

## Discord + ModMail settings
## Required bot token from Discord Developer Portal
DISCORD_TOKEN=
## Required Discord server (guild) ID where ticket channels are created
GUILD_ID=
## Required category ID where ticket channels should be created
STAFF_CATEGORY_ID=
## Optional staff role ID allowed to view/respond in ticket channels
STAFF_ROLE_ID=
## Optional channel ID for close logs/transcripts/notes
LOG_CHANNEL_ID=
## Prefix commands in staff channel, e.g. !close !note !reopen
COMMAND_PREFIX=!
## Keep this as /data/modmail.sqlite when `/data` is mapped in Unraid
DB_PATH=/data/modmail.sqlite
## true = register/use slash commands; false = prefix commands only
ENABLE_SLASH_COMMANDS=true
## 0s disables auto-delete (recommended to start). Examples: 30m, 24h
AUTO_DELETE_CLOSED_TICKET_AFTER=0s
## Staff display mode in user DMs: anonymous | named | role
STAFF_IDENTITY=anonymous
## Label shown when STAFF_IDENTITY=role
STAFF_REPLY_LABEL=Moderator
## Logging verbosity: debug | info | warn | error
LOG_LEVEL=info
